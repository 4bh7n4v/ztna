[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
req_extensions     = v3_req
distinguished_name = dn

[ dn ]
C  = IN
ST = Kerala
L  = Amritapuri
O  = MyOrg
OU = SDP
CN = __COMMON_NAME__

[ v3_req ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = __DNS_NAME__
IP.1  = __IP_ADDRESS__
