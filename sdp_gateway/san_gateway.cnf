[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
req_extensions     = v3_req
distinguished_name = dn

[ dn ]
C  = IN
ST = Kerala
L  = Amritapuri
O  = MyOrg
OU = Gateway
CN = gateway.local

[ v3_req ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1   = gateway.local
IP.1    = 192.168.233.247
